rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 已登入使用者只能讀寫自己的資料夾
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // 其他路徑一律拒絕
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
